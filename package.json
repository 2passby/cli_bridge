{
  "name": "botbridge",
  "version": "0.0.0",
  "description": "Bridge between IM platforms and AI coding CLIs \u2014 one topic, one CLI session with live streaming",
  "type": "module",
  "main": "dist/index-daemon.js",
  "bin": {
    "botbridge": "dist/cli.js"
  },
  "files": [
    "dist/",
    "ecosystem.config.cjs",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "daemon": "tsx src/index-daemon.ts",
    "daemon:start": "node dist/cli.js start",
    "daemon:stop": "node dist/cli.js stop",
    "daemon:restart": "node dist/cli.js restart",
    "daemon:logs": "node dist/cli.js logs",
    "daemon:status": "node dist/cli.js status",
    "test": "vitest run",
    "test:codex": "vitest run test/codex-input.e2e.ts",
    "test:gemini": "vitest run test/gemini-input.e2e.ts",
    "test:e2e-browser:setup": "tsx test/e2e-browser/setup-login.ts",
    "test:e2e-browser": "vitest run test/e2e-browser/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@napi-rs/canvas": "^0.1.65",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/headless": "^6.0.0",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "node-pty": "^1.1.0",
    "pm2": "^6.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@midscene/web": "^1.6.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.39",
    "@types/ws": "^8.18.1",
    "memfs": "^4.57.1",
    "playwright": "^1.58.2",
    "tsx": "^4.20.5",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "packageManager": "pnpm@8.15.1+sha512.831cf4c5f8b8374af71521d4d153db49d7086de615c2af7cb5e9d7eb8ba630ddac46fea495d643e552ef2e68a3aa99a3e5e9fbee8696702967504df5c59cb273"
}
